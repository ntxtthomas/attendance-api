# Copy to .env and fill in with real values (DO NOT COMMIT .env)
# Example .env entries for local development

# Postgres DB URL (optional, overrides individual DB settings)
# DATABASE_URL=postgres://attendance_user:your_password@localhost:5432/attendance_api_development

# PgHero HTTP Basic credentials (required to access /pghero)
PGHERO_USER=your_pghero_user
PGHERO_PASSWORD=your_strong_password

# Devise JWT secret (optional override)
# DEVISE_JWT_SECRET_KEY=your_long_secret
